# PostgreSQL connection string used by Prisma.
# Example for a local Docker/Postgres database:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/echive?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# AI provider settings are intentionally left blank for Day 1 Foundation.
# Add provider-specific keys when Milestone 2 starts.
