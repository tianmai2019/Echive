# PostgreSQL container settings used by docker-compose.yml.
POSTGRES_USER="echive"
POSTGRES_PASSWORD="echive_dev_password"
POSTGRES_DB="echive"
POSTGRES_PORT="5432"

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://echive:echive_dev_password@localhost:5432/echive?schema=public"

# AI provider settings are intentionally left blank for Foundation.
# Add provider-specific keys when Milestone 2 starts.
