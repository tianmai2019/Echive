# Echive is local-first. The default development database runs on this machine.
# Remote databases should only be used as a personal developer convenience.

# PostgreSQL container settings used by docker-compose.yml.
POSTGRES_USER="echive"
POSTGRES_PASSWORD="echive_dev_password"
POSTGRES_DB="echive"
POSTGRES_PORT="5432"

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://echive:echive_dev_password@localhost:5432/echive?schema=public"

# Optional personal remote development database via SSH tunnel:
# ssh -L 5433:127.0.0.1:5432 user@your-server-ip
# DATABASE_URL="postgresql://echive_dev:change_me@127.0.0.1:5433/echive_dev_remote?schema=public"

# AI provider settings are intentionally left blank for Foundation.
# Add provider-specific keys when Milestone 2 starts.
