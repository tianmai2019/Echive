# ============================================================
# 🔒 项目配置说明 - 所有开发环境统一使用阿里云远程数据库
# ============================================================
#
# 重要：不要直接修改此文件！此文件是模板。
# 请复制此文件为 `.env.local`，然后在 `.env.local` 中填写你的实际配置。
# `.env.local` 不会被提交到 git，确保各环境配置不会互相覆盖。
#
# 数据库连接流程：
# 1. 本地启动 SSH tunnel 连接到阿里云服务器
# 2. 通过本地端口转发访问远程 PostgreSQL
# 3. 所有开发者共享同一个远程开发数据库
#
# ============================================================

# ──────────────────────────────────────────
# 第一步：配置 SSH 隧道别名（只需配置一次）
# ──────────────────────────────────────────
#
# macOS / Linux: 在 ~/.ssh/config 中添加:
# Host aliyun-dev
#   HostName 121.40.165.144
#   User root
#   IdentityFile ~/.ssh/echive_aliyun_dev
#   Port 22
#   ServerAliveInterval 60
#   ServerAliveCountMax 3
#
# Windows (PowerShell): 在 C:\Users\你的用户名\.ssh\config 中添加同上内容
#
# ──────────────────────────────────────────
# 第二步：启动 SSH 隧道（每次开发前运行）
# ──────────────────────────────────────────
#
# 所有系统通用命令：
#   ssh -N aliyun-dev
#
# Windows PowerShell 完整版（带连接检测）：
#   ssh -o ExitOnForwardFailure=yes -N -L 5433:127.0.0.1:5432 aliyun-dev
#
# ──────────────────────────────────────────
# 第三步：验证连接
# ──────────────────────────────────────────
#
# PowerShell:
#   Test-NetConnection -ComputerName 127.0.0.1 -Port 5433
#
# macOS / Linux:
#   nc -zv 127.0.0.1 5433
#
# Prisma 验证：
#   pnpm prisma migrate status
#
# ============================================================
# 👇 下面是需要复制到 .env.local 的实际配置项
# ============================================================

# PostgreSQL connection string - 阿里云远程开发数据库
# SSH tunnel 将本地 5433 端口转发到阿里云服务器的 5432 端口
DATABASE_URL="postgresql://echive_dev:Echive@2025@127.0.0.1:5433/echive_dev_remote?schema=public"

# Docker PostgreSQL 配置（已弃用，仅作备份参考）
# 所有环境现在统一使用阿里云远程数据库
POSTGRES_USER="echive"
POSTGRES_PASSWORD="echive_dev_password"
POSTGRES_DB="echive"
POSTGRES_PORT="5432"

# AI provider settings are intentionally left blank for Foundation.
# Add provider-specific keys when Milestone 2 starts.
